# Azure DevOps
# PAT with Code (Read/Write), Packaging (Read) scopes
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/iwgplc
AZURE_DEVOPS_DEFAULT_PROJECTS=Titan,CountryOnboarding

# Atlassian
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
ATLASSIAN_CLOUD_ID=
ATLASSIAN_EMAIL=

# NuGet feed authentication
# Azure DevOps PAT with Packaging > Read scope
# Note: the actual env var used by nuget.config is `heimdall-access-token` (a Machine-level
# env var with a hyphenated name). If that Machine-level var is already set, leave this blank.
# If not, this value will be injected into the process environment at clone time.
NUGET_FEED_PAT=
